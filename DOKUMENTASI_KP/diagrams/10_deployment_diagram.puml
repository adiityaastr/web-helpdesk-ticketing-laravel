@startuml 10_deployment_diagram
!define DIRECTION top to bottom
skinparam linetype ortho
skinparam backgroundColor #FEFEFE
skinparam node {
    BackgroundColor #E8F5E9
    BorderColor #388E3C
}

node "Server Lokal (XAMPP/Laragon)" as host {
    node "Apache/PHP 8.3" as apache {
        artifact "Laravel 13" as laravel
        artifact "Inertia.js" as inertia
        artifact "React 19" as react
    }

    node "MySQL 8.0" as mysql {
        artifact "Database helpdesk_db" as db_data
    }

    node "File Storage" as storage {
        artifact "Session (file)" as session
        artifact "Cache (file)" as cache
        artifact "Uploads" as uploads
    }
}

node "Mesin Klien" as client {
    artifact "Browser" as browser
}

node "Build Tools" as tools {
    artifact "Node.js + Vite" as vite
    artifact "Tailwind CSS 4" as tailwind
}

browser --> apache : HTTP:8000
apache --> mysql : TCP:3306
apache --> storage : File I/O
tools --> apache : Build Assets

note right of apache
  php artisan serve
  Port: 8000
end note

note right of mysql
  Host: 127.0.0.1
  User: root
  DB: helpdesk_db
end note

note right of storage
  storage/framework/sessions
  storage/framework/cache
  storage/app/public
end note

@enduml
