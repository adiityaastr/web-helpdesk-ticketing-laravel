@startuml 05_flowchart_login
!define DIRECTION top to bottom
skinparam linetype ortho
skinparam backgroundColor #FEFEFE

start
:Pengguna buka halaman login;
:Input email & password;
:Klik tombol Login;

:Validasi input;
if (Email & password valid?) then (Tidak)
    :Tampilkan pesan error;
    :Pengguna input ulang;
else (Ya)
    :Cari user by email;
    
    if (User ditemukan?) then (Tidak)
        :Tampilkan "Email tidak terdaftar";
        :Pengguna input ulang;
    else (Ya)
        :Verifikasi password dengan bcrypt;
        
        if (Password benar?) then (Tidak)
            :Tampilkan "Password salah";
            :Pengguna input ulang;
        else (Ya)
            :Cek status user;
            
            if (User aktif?) then (Tidak)
                :Tampilkan "User tidak aktif";
            else (Ya)
                :Generate session token;
                :Simpan session di Redis;
                :Set session lifetime = 120 menit;
                
                :Generate API token (Sanctum);
                :Simpan token di database;
                
                :Buat auth cookie;
                :Set cookie secure & httpOnly;
                
                :Catat aktivitas login;
                
                :Redirect ke dashboard;
                :Tampilkan pesan selamat datang;
            endif
        endif
    endif
endif

stop

note right
  Keamanan:
  - Password hashing (bcrypt)
  - Session storage (Redis)
  - Cookie aman (httpOnly)
  - Pencatatan aktivitas
end note

@enduml
