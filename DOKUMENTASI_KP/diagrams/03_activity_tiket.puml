@startuml 03_activity_tiket
!define DIRECTION top to bottom
skinparam linetype ortho
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #FAFAFA
    BorderColor #333
    FontSize 11
}

start
:Pelanggan buka form buat tiket;
:Isi judul, deskripsi, kategori;
:Upload lampiran (opsional);
:Submit form;

if (Validasi input?) then (Gagal)
    :Tampilkan pesan error;
    stop
else (Berhasil)
    :Buat tiket baru di database;
    :Generate UUID tiket;
    :Set status = "open";
    :Set prioritas = default;

    :Kirim event TiketDibuat;
    
    :Hitung skor SAW;
    :Cache skor ke Redis;
    
    :Kirim notifikasi ke admin;
    :Catat aktivitas;
    
    :Kembalikan response sukses;
    :Redirect ke detail tiket;
    
    :Admin lihat tiket baru;
    :Review tiket;
    
    if (Assign ke staff?) then (Ya)
        :Assign tiket ke staff;
        :Set assigned_to = staff_id;
        :Kirim notifikasi ke staff;
        :Update status = "in_progress";
    else (Tidak)
        :Tiket tetap unassigned;
    endif
    
    :Staff lihat tiket;
    :Baca deskripsi & lampiran;
    :Tambah komentar (publik/internal);
    
    if (Tiket selesai?) then (Ya)
        :Update status = "resolved";
        :Set resolved_at = now;
        :Kirim notifikasi ke pelanggan;
        :Pelanggan lihat notifikasi;
        
        if (Pelanggan konfirmasi selesai?) then (Ya)
            :Update status = "closed";
            :Set resolved_confirmed_at = now;
            :Tampilkan form rating;
            :Pelanggan beri rating 1-5;
            :Simpan rating & komentar;
            :Tiket selesai;
        else (Tidak)
            :Update status = "in_progress";
            :Staff lanjut handle tiket;
        endif
    else (Tidak)
        :Staff lanjut handle tiket;
    endif
    
    if (Pelanggan batalkan?) then (Ya)
        :Update status = "cancelled";
        :Set cancelled_at = now;
        :Kirim notifikasi ke staff;
        stop
    else (Tidak)

    endif
endif

stop

@enduml
