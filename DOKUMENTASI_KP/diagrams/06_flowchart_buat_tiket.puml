@startuml 06_flowchart_buat_tiket
!define DIRECTION top to bottom
skinparam linetype ortho
skinparam backgroundColor #FEFEFE

start
:Pelanggan buka form buat tiket;
:Input judul tiket;
:Input deskripsi;
:Pilih kategori;
:Upload lampiran (opsional);

:Validasi input;
if (Judul kosong?) then (Ya)
    :Error: Judul harus diisi;
    :Pelanggan perbaiki;
else (Tidak)
    if (Deskripsi kosong?) then (Ya)
        :Error: Deskripsi harus diisi;
        :Pelanggan perbaiki;
    else (Tidak)
        if (Kategori valid?) then (Tidak)
            :Error: Kategori tidak valid;
            :Pelanggan pilih ulang;
        else (Ya)
            if (Ada lampiran?) then (Ya)
                :Validasi file;
                if (Ukuran file > 20MB?) then (Ya)
                    :Error: File terlalu besar;
                    :Pelanggan upload ulang;
                else (Tidak)
                    if (Tipe file aman?) then (Tidak)
                        :Error: Tipe file tidak diizinkan;
                        :Pelanggan upload ulang;
                    else (Ya)
                        :Simpan file ke storage;
                        :Generate path file;
                    endif
                endif
            else (Tidak)
                :Lanjut tanpa lampiran;
            endif
            
            :Buat record tiket baru;
            :Set user_id = current user;
            :Set category_id = kategori terpilih;
            :Set status = "open";
            :Set prioritas = "medium" (default);
            :Set created_at = now;
            
            :Generate UUID tiket;
            :Hitung skor SAW;
            :Cache skor ke Redis;
            
            :Kirim event TiketDibuat;
            :Kirim notifikasi ke admin;
            :Catat aktivitas;
            
            :Kembalikan response sukses;
            :Redirect ke detail tiket;
            :Tampilkan pesan sukses;
        endif
    endif
endif

stop

note right
  Validasi:
  - Judul & deskripsi tidak kosong
  - Kategori valid
  - Ukuran file < 20MB
  - Tipe file aman
  
  Proses:
  - Buat record tiket
  - Hitung skor SAW
  - Kirim notifikasi
  - Catat aktivitas
end note

@enduml
