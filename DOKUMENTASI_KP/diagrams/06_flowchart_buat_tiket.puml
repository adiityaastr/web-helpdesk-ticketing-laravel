@startuml 06_flowchart_buat_tiket
!define DIRECTION top to bottom
skinparam linetype ortho
skinparam backgroundColor #FEFEFE

start
:Customer buka form buat tiket;
:Input judul tiket;
:Input deskripsi;
:Pilih kategori;
:Upload lampiran (optional);

:Validasi input;
if (Judul kosong?) then (Ya)
    :Error: Judul harus diisi;
    :Customer perbaiki;
else (Tidak)
    if (Deskripsi kosong?) then (Ya)
        :Error: Deskripsi harus diisi;
        :Customer perbaiki;
    else (Tidak)
        if (Kategori valid?) then (Tidak)
            :Error: Kategori tidak valid;
            :Customer pilih ulang;
        else (Ya)
            if (Ada lampiran?) then (Ya)
                :Validasi file;
                if (File size > 20MB?) then (Ya)
                    :Error: File terlalu besar;
                    :Customer upload ulang;
                else (Tidak)
                    if (File type aman?) then (Tidak)
                        :Error: Tipe file tidak diizinkan;
                        :Customer upload ulang;
                    else (Ya)
                        :Simpan file ke storage;
                        :Generate file path;
                    endif
                endif
            else (Tidak)
                :Lanjut tanpa lampiran;
            endif
            
            :Create Ticket record;
            :Set user_id = current user;
            :Set category_id = selected category;
            :Set status = "open";
            :Set priority = "medium" (default);
            :Set created_at = now;
            
            :Generate UUID tiket;
            :Hitung SAW score;
            :Cache score ke Redis;
            
            :Dispatch TicketCreated event;
            :Send notification ke admin;
            :Log activity;
            
            :Return success response;
            :Redirect ke detail tiket;
            :Tampilkan success message;
        endif
    endif
endif

stop

note right
  Validasi:
  - Judul & deskripsi tidak kosong
  - Kategori valid
  - File size < 20MB
  - File type aman
  
  Proses:
  - Create ticket record
  - Calculate SAW score
  - Send notification
  - Log activity
end note

@enduml
