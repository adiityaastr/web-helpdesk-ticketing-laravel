@startuml 01_arsitektur_sistem

skinparam linetype ortho
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 12

skinparam component {
    BorderColor #333
    BackgroundColor #FEFEFE
    FontSize 11
}

skinparam package {
    BorderColor #1565C0
    BackgroundColor #E3F2FD
    FontColor #1565C0
    FontSize 14
    FontStyle bold
}

package "LAYER KLIEN" as client_layer #E1F5FE {
    component [Browser\n(React 19 + Inertia.js)] as browser
}

package "LAYER PRESENTASI" as pres_layer #FFF3E0 {
    component [Apache / PHP Built-in Server\nPort 8000] as webserver
}

package "LAYER APLIKASI" as app_layer #F3E5F5 {
    component [PHP 8.3\nLaravel 13] as phpfpm
    component [Service\n(SAW, Notifikasi, Tiket)] as services
    component [Controller\n(Admin, Portal, API)] as controllers
    component [Middleware\n(Auth, Role, CSRF)] as middleware
}

package "LAYER DATA" as data_layer #E8F5E9 {
    component [MySQL 8.0\nDatabase] as mysql
    component [File Storage\nSession & Cache] as filestorage
}

browser --> webserver : HTTP
webserver --> middleware : Request
middleware --> controllers : Route
controllers --> services : Logika Bisnis
services --> mysql : Query (Eloquent)
services --> filestorage : Cache/Session

note right of browser
  Komponen React 19
  Tailwind CSS 4
  Chart.js
end note

note right of webserver
  XAMPP / Laragon
  php artisan serve
end note

note right of services
  TicketService
  SawService
  DashboardService
  NotificationService
  CommentService
end note

note right of mysql
  9 Tabel Utama
  Engine InnoDB
  Charset utf8mb4
end note

note right of filestorage
  SESSION_DRIVER=file
  CACHE_STORE=file
  QUEUE_CONNECTION=sync
end note

@enduml
