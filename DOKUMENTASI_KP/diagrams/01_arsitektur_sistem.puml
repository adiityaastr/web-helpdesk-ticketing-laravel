@startuml 01_arsitektur_sistem

skinparam linetype ortho
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 12

skinparam component {
    BorderColor #333
    BackgroundColor #FEFEFE
    FontSize 11
}

skinparam package {
    BorderColor #1565C0
    BackgroundColor #E3F2FD
    FontColor #1565C0
    FontSize 14
    FontStyle bold
}

package "LAYER KLIEN" as client_layer #E1F5FE {
    component [Browser\n(React 19)] as browser
}

package "LAYER PRESENTASI" as pres_layer #FFF3E0 {
    component [Nginx 1.26\nWeb Server] as nginx
}

package "LAYER APLIKASI" as app_layer #F3E5F5 {
    component [PHP-FPM 8.3\nLaravel 13] as phpfpm
    component [Service\n(SAW, Notifikasi)] as services
    component [Controller\n(Tiket, User, dsb)] as controllers
}

package "LAYER DATA" as data_layer #E8F5E9 {
    component [MySQL 8.0\nDatabase] as mysql
}

package "LAYER CACHE" as cache_layer #E0F7FA {
    component [Redis 7\nCache & Session] as redis
}

package "LAYER ANTRIAN" as queue_layer #FCE4EC {
    component [Redis Antrian\nWorker] as queue
}

package "LAYAR EKSTERNAL" as ext_layer #F5F5F5 {
    component [MailHog\nTesting Email] as mailhog
    component [Adminer\nManajemen DB] as adminer
}

browser --> nginx : HTTP/HTTPS
nginx --> phpfpm : FastCGI
phpfpm --> controllers : Route
controllers --> services : Logika Bisnis
services --> mysql : Query
services --> redis : Cache/Session
phpfpm --> queue : Kirim Job
queue --> redis : Ambil Job
queue --> mysql : Simpan Hasil
phpfpm --> mailhog : Kirim Email
adminer --> mysql : Kelola DB

note right of browser
  Komponen React
  Tailwind CSS
  Inertia.js Client
end note

note right of nginx
  Reverse Proxy
  Aset Statis
  SSL/TLS
  Kompresi Gzip
end note

note right of phpfpm
  Penangan Request
  Middleware
  Cek Policy
end note

note right of services
  SawService
  NotificationService
  TicketService
end note

note right of mysql
  8 Tabel
  Engine InnoDB
  Charset utf8mb4
end note

note right of redis
  Penyimpanan Session
  Cache Query
  Skor SAW
end note

note right of queue
  Pekerjaan Async
  Notifikasi
  Pengiriman Email
end note

@enduml
