@startuml 08_sequence_tiket
!define DIRECTION top to bottom
skinparam linetype ortho
skinparam backgroundColor #FEFEFE

actor Pelanggan
participant "Browser\n(React)" as browser
participant "Nginx" as nginx
participant "Controller\nLaravel" as controller
participant "TicketService" as service
participant "Database\n(MySQL)" as db
participant "Redis\nCache" as cache
participant "Antrian\nWorker" as queue
participant "Notifikasi" as notif

Pelanggan -> browser: Buka form buat tiket
browser -> browser: Render form
Pelanggan -> browser: Isi data & submit
browser -> nginx: POST /tickets
nginx -> controller: Route ke TicketController@store
controller -> controller: Validasi input
controller -> service: createTicket(data)
service -> db: INSERT tiket
db -> service: ticket_id
service -> cache: calculateSAW(tiket)
cache -> service: skor_saw
service -> db: UPDATE tiket skor SAW
service -> queue: Kirim TicketCreatedJob
queue -> queue: Antri job
service -> controller: return tiket
controller -> browser: Response Inertia
browser -> browser: Render sukses
browser -> Pelanggan: Tampilkan detail tiket

queue -> notif: Eksekusi SendNotificationJob
notif -> db: INSERT notifikasi
notif -> db: UPDATE read_at notifikasi
notif -> browser: Broadcast notifikasi (opsional)
browser -> Pelanggan: Tampilkan notifikasi

note over service
  Perhitungan SAW:
  - Normalisasi 5 kriteria
  - Weighted sum
  - Cache 60 detik
end note

note over queue
  Pemrosesan Async:
  - Kirim notifikasi
  - Kirim email
  - Catat aktivitas
end note

@enduml
