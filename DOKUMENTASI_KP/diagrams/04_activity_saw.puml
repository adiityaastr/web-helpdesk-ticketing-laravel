@startuml 04_activity_saw
!define DIRECTION top to bottom
skinparam linetype ortho
skinparam backgroundColor #FEFEFE

start
:Minta daftar tiket;
:Cek cache Redis;

if (Cache ada?) then (Ya)
    :Kembalikan skor SAW dari cache;
    :Urutkan tiket by skor DESC;
else (Tidak)
    :Ambil semua tiket dari DB;
    :Ambil konfigurasi SAW dari DB;
    
    partition "Normalisasi Data" {
        :Ekstrak nilai C1 (Prioritas);
        :Ekstrak nilai C2 (Urgensi SLA);
        :Ekstrak nilai C3 (Waktu Tunggu);
        :Ekstrak nilai C4 (Aktivitas Pelanggan);
        :Ekstrak nilai C5 (Kompleksitas);
        
        :Normalisasi C1 (benefit);
        :r1 = C1 / max(C1);
        
        :Normalisasi C2 (benefit);
        :r2 = C2 / max(C2);
        
        :Normalisasi C3 (cost);
        :r3 = min(C3) / C3;
        
        :Normalisasi C4 (benefit);
        :r4 = C4 / max(C4);
        
        :Normalisasi C5 (benefit);
        :r5 = C5 / max(C5);
    }
    
    partition "Weighted Sum" {
        :Ambil bobot W1, W2, W3, W4, W5;
        :Hitung V(i) = (W1*r1) + (W2*r2) + (W3*r3) + (W4*r4) + (W5*r5);
        :Simpan V(i) untuk setiap tiket;
    }
    
    partition "Peringkat" {
        :Urutkan tiket by V(i) DESC;
        :Assign peringkat 1, 2, 3, ...;
    }
    
    :Cache skor SAW ke Redis;
    :Set TTL = 60 detik;
endif

:Kembalikan tiket terurut dengan skor;
:Render di frontend;
:Tampilkan peringkat & skor;

stop

note right
  Rumus SAW:
  V(i) = Sum(w_j * r_ij)
  
  Dimana:
  - w_j = bobot kriteria j
  - r_ij = nilai normalisasi
  - i = tiket ke-i
  - j = kriteria ke-j
end note

@enduml
